# AI Provider Configuration
# Choose one of: openai, anthropic, gemini
NEXT_PUBLIC_AI_PROVIDER=openai
NEXT_PUBLIC_AI_MODEL=gpt-4-turbo

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic
