# AI Provider Configuration (REQUIRED)
# Choose one: openai, anthropic, gemini
NEXT_PUBLIC_AI_PROVIDER=openai

# Model selection (REQUIRED)
# For OpenAI: gpt-4-turbo, gpt-4, gpt-3.5-turbo
# For Anthropic: claude-3-opus-20240229, claude-3-sonnet-20240229, claude-3-haiku-20240307
# For Gemini: gemini-pro, gemini-1.5-pro
NEXT_PUBLIC_AI_MODEL=gpt-4-turbo

# API Keys (add the one for your chosen provider)

# OpenAI - Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk_test_your_openai_key_here

# Anthropic - Get from https://console.anthropic.com/keys
ANTHROPIC_API_KEY=sk_ant_your_anthropic_key_here

# Google Gemini - Get from https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_google_gemini_key_here

# Email Configuration (OPTIONAL - for consultation notifications)
# Gmail SMTP credentials
# Get app-specific password from: https://myaccount.google.com/apppasswords
GMAIL_EMAIL=cod3blackagency@gmail.com
GMAIL_APP_PASSWORD=your_16_character_app_password_here
